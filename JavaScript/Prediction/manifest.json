{
  "manifest_version": 3,
  "name": "Prediction Market Scraper",
  "version": "1.3",
  "description": "抓取Polymarket和Kalshi预测市场数据",
  "permissions": [
    "activeTab",
    "tabs",
    "downloads",
    "scripting"
  ],
  "host_permissions": [
    "https://polymarket.com/*",
    "https://kalshi.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Prediction Market Scraper"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://polymarket.com/*",
        "https://kalshi.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}